{
    "version": "0.2.0",
    "configurations": [
        // ── Argus ──────────────────────────────────────────────────────────
        {
            "type": "cppvsdbg",
            "request": "launch",
            "name": "Argus",
            "program": "${workspaceFolder}/target/debug/argus.exe",
            "args": [
                "-c", "configs/default.ini",
                "--log", "logs.txt",
                "--verbose"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "cargo build (debug)",
            "console": "integratedTerminal"
        },
        // ── Python interceptor ──────────────────────────────────────────────
        {
            "type": "debugpy",
            "request": "launch",
            "name": "Interceptor",
            "program": "${workspaceFolder}/python/example_interceptor.py",
            "args": [
                "--host", "127.0.0.1",
                "--port", "9999",
                "--debug"
            ],
            "cwd": "${workspaceFolder}/python",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
